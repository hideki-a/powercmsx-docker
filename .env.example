# ================================================================
# PowerCMS X ローカル開発環境 – 環境変数テンプレート
#
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# .env は .gitignore で除外されているためコミットされません。
# ================================================================

# PHP
PHP_VERSION=8.3

# MySQL
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=powercmsx
MYSQL_USER=powercmsx
MYSQL_PASSWORD=your_password

# Redis（変更不要）
REDIS_PORT=6379
